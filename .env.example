# Copy this file to .env and fill values locally.
# Do not commit .env.

ALIO_API_KEY=
CLEANEYE_API_KEY=
OPENAI_API_KEY=
NOTION_TOKEN=

# Comma-separated browser origins allowed to call the HTTP MCP endpoint.
# Requests without an Origin header (e.g. CLI and server-to-server clients) are unaffected.
# Example: MCP_ALLOWED_ORIGINS=https://your-mcp-client.example
MCP_ALLOWED_ORIGINS=
